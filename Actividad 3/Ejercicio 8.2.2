import tkinter as tk
from tkinter import ttk, messagebox
import math


# ================== CLASE LÓGICA ==================
class Notas:
    def __init__(self, lista_notas):
        self.lista_notas = lista_notas

    def calcular_promedio(self):
        return sum(self.lista_notas) / len(self.lista_notas)

    def calcular_desviacion(self):
        promedio = self.calcular_promedio()
        suma = sum((nota - promedio) ** 2 for nota in self.lista_notas)
        return math.sqrt(suma / len(self.lista_notas))

    def calcular_mayor(self):
        return max(self.lista_notas)

    def calcular_menor(self):
        return min(self.lista_notas)


# ================== FUNCIONES ==================
class Funciones_Ventana:
    @staticmethod
    def calcular():
        try:
            valores = [entrada.get() for entrada in entradas]

            # Validar campos vacíos
            if not all(valores):
                messagebox.showerror("Error", "Debe ingresar las 5 notas.")
                return

            # Convertir a números
            notas_lista = [float(valor) for valor in valores]

            # Validar que no sean negativas
            if any(nota < 0 for nota in notas_lista):
                messagebox.showerror("Error", "Las notas no pueden ser negativas.")
                return

            # Crear objeto
            notas = Notas(notas_lista)

            # Mostrar resultados
            lbl_promedio.config(
                text=f"Promedio = {notas.calcular_promedio():.2f}"
            )
            lbl_desviacion.config(
                text=f"Desviación estándar = {notas.calcular_desviacion():.2f}"
            )
            lbl_mayor.config(
                text=f"Valor mayor = {notas.calcular_mayor()}"
            )
            lbl_menor.config(
                text=f"Valor menor = {notas.calcular_menor()}"
            )

        except ValueError:
            messagebox.showerror(
                "Error",
                "Ingrese solo valores numéricos.\nUse punto decimal: 4.5"
            )

    @staticmethod
    def limpiar():
        for entrada in entradas:
            entrada.delete(0, tk.END)

        lbl_promedio.config(text="Promedio = ")
        lbl_desviacion.config(text="Desviación estándar = ")
        lbl_mayor.config(text="Valor mayor = ")
        lbl_menor.config(text="Valor menor = ")

        entradas[0].focus()


# ================== VENTANA ==================
ventana = tk.Tk()
ventana.title("Notas del estudiante")
ventana.geometry("280x380")
ventana.configure(padx=20, pady=20)

style = ttk.Style()
style.theme_use("clam")

# ================== ENTRADAS ==================
entradas = []

for i in range(5):
    ttk.Label(
        ventana,
        text=f"Nota {i+1}:"
    ).grid(row=i, column=0, padx=10, pady=5)

    entrada = ttk.Entry(ventana, width=14)
    entrada.grid(row=i, column=1, padx=10, pady=5)

    entradas.append(entrada)

# ================== BOTONES ==================
btn_calcular = ttk.Button(
    ventana,
    text="Calcular",
    command=Funciones_Ventana.calcular
)
btn_calcular.grid(row=5, column=0, pady=15, padx=(20, 5))

btn_limpiar = ttk.Button(
    ventana,
    text="Limpiar",
    command=Funciones_Ventana.limpiar
)
btn_limpiar.grid(row=5, column=1, pady=15, padx=(10, 10))

# ================== RESULTADOS ==================
lbl_promedio = ttk.Label(ventana, text="Promedio = ")
lbl_promedio.grid(row=6, column=0, columnspan=2, sticky="w", padx=10)

lbl_desviacion = ttk.Label(
    ventana,
    text="Desviación estándar = "
)
lbl_desviacion.grid(row=7, column=0, columnspan=2, sticky="w", padx=10)

lbl_mayor = ttk.Label(ventana, text="Valor mayor = ")
lbl_mayor.grid(row=8, column=0, columnspan=2, sticky="w", padx=10)

lbl_menor = ttk.Label(ventana, text="Valor menor = ")
lbl_menor.grid(row=9, column=0, columnspan=2, sticky="w", padx=10)

ventana.mainloop()