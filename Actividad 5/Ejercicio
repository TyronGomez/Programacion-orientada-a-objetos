    # =====================================================
    # BUSCAR ARCHIVO
    # =====================================================
    def buscar_archivo(self):

        archivo = filedialog.askopenfilename(
            title="Seleccionar TXT",
            filetypes=[("Archivos TXT", "*.txt")]
        )

        if archivo:

            self.ruta_archivo = archivo

            self.entry_ruta.delete(0, tk.END)

            self.entry_ruta.insert(
                0,
                archivo
            )

    # =====================================================
    # OBTENER AGENDA
    # =====================================================
    def obtener_agenda(self):

        ruta = self.entry_ruta.get()

        if not ruta:

            raise ValueError(
                "Debe seleccionar un archivo TXT."
            )

        return Agenda(ruta)

    # =====================================================
    # AGREGAR
    # =====================================================
    def agregar_contacto(self):

        try:

            agenda = self.obtener_agenda()

            contacto = Contacto(
                self.entry_nombre.get(),
                self.entry_telefono.get(),
                self.entry_correo.get(),
                self.entry_ciudad.get(),
                self.combo_categoria.get()
            )

            agenda.agregar_contacto(contacto)

            self.mostrar_contactos()

            self.historial.insert(
                tk.END,
                f"✅ Contacto agregado: "
                f"{contacto.get_nombre()}\n"
            )

            messagebox.showinfo(
                "Éxito",
                "Contacto agregado correctamente."
            )

            self.limpiar()

        except Exception as e:

            messagebox.showerror(
                "Error",
                str(e)
            )

    # =====================================================
    # MOSTRAR
    # =====================================================
    def mostrar_contactos(self):

        try:

            agenda = self.obtener_agenda()

            contactos = agenda.leer_contactos()

            # LIMPIAR TABLA
            for item in self.tabla.get_children():
                self.tabla.delete(item)

            # INSERTAR DATOS
            for contacto in contactos:

                self.tabla.insert(
                    "",
                    tk.END,
                    values=(
                        contacto.get_nombre(),
                        contacto.get_telefono(),
                        contacto.get_correo(),
                        contacto.get_ciudad(),
                        contacto.get_categoria()
                    )
                )

            self.actualizar_reporte()

        except Exception as e:

            messagebox.showerror(
                "Error",
                str(e)
            )

    # =====================================================
    # BUSCAR CONTACTO
    # =====================================================
    def buscar_contacto(self):

        try:

            agenda = self.obtener_agenda()

            telefono = self.entry_telefono.get()

            contacto = agenda.buscar_contacto(
                telefono
            )

            if contacto is None:

                messagebox.showwarning(
                    "Búsqueda",
                    "Contacto no encontrado."
                )

                return

            self.entry_nombre.delete(0, tk.END)
            self.entry_nombre.insert(
                0,
                contacto.get_nombre()
            )

            self.entry_correo.delete(0, tk.END)
            self.entry_correo.insert(
                0,
                contacto.get_correo()
            )

            self.entry_ciudad.delete(0, tk.END)
            self.entry_ciudad.insert(
                0,
                contacto.get_ciudad()
            )

            self.combo_categoria.set(
                contacto.get_categoria()
            )

            messagebox.showinfo(
                "Contacto encontrado",
                contacto.mostrar_datos()
            )

        except Exception as e:

            messagebox.showerror(
                "Error",
                str(e)
            )

    # =====================================================
    # ELIMINAR
    # =====================================================
    def eliminar_contacto(self):

        try:

            agenda = self.obtener_agenda()

            telefono = self.entry_telefono.get()

            agenda.eliminar_contacto(telefono)

            self.mostrar_contactos()

            self.historial.insert(
                tk.END,
                f"❌ Contacto eliminado: "
                f"{telefono}\n"
            )

            messagebox.showinfo(
                "Eliminado",
                "Contacto eliminado correctamente."
            )

            self.limpiar()

        except Exception as e:

            messagebox.showerror(
                "Error",
                str(e)
            )

    # =====================================================
    # ACTUALIZAR
    # =====================================================
    def actualizar_contacto(self):

        try:

            agenda = self.obtener_agenda()

            telefono_original = self.entry_telefono.get()

            contacto_actualizado = Contacto(
                self.entry_nombre.get(),
                self.entry_telefono.get(),
                self.entry_correo.get(),
                self.entry_ciudad.get(),
                self.combo_categoria.get()
            )

            agenda.actualizar_contacto(
                telefono_original,
                contacto_actualizado
            )

            self.mostrar_contactos()

            self.historial.insert(
                tk.END,
                f"🔄 Contacto actualizado: "
                f"{contacto_actualizado.get_nombre()}\n"
            )

            messagebox.showinfo(
                "Actualizado",
                "Contacto actualizado correctamente."
            )

        except Exception as e:

            messagebox.showerror(
                "Error",
                str(e)
            )

    # =====================================================
    # CARGAR DESDE TABLA
    # =====================================================
    def cargar_desde_tabla(self, event):

        seleccionado = self.tabla.selection()

        if not seleccionado:
            return

        valores = self.tabla.item(
            seleccionado[0],
            "values"
        )

        self.limpiar()

        self.entry_nombre.insert(0, valores[0])
        self.entry_telefono.insert(0, valores[1])
        self.entry_correo.insert(0, valores[2])
        self.entry_ciudad.insert(0, valores[3])

        self.combo_categoria.set(valores[4])

    # =====================================================
    # REPORTE
    # =====================================================
    def actualizar_reporte(self):

        agenda = self.obtener_agenda()

        self.lbl_reporte.config(

            text=(
                f"Total contactos: "
                f"{agenda.total_contactos()} | "
                f"Ciudades: "
                f"{agenda.total_ciudades()} | "
                f"Categorías: "
                f"{agenda.total_categorias()}"
            )
        )

    # =====================================================
    # LIMPIAR
    # =====================================================
    def limpiar(self):

        self.entry_nombre.delete(0, tk.END)

        self.entry_telefono.delete(0, tk.END)

        self.entry_correo.delete(0, tk.END)

        self.entry_ciudad.delete(0, tk.END)

        self.combo_categoria.set("")


