import os

# =========================================================
# CLASE PERSONA
# =========================================================
class Persona:

    def __init__(self, nombre, telefono):
        self.validar_nombre(nombre)
        self.validar_telefono(telefono)

        self._nombre = nombre
        self._telefono = telefono

    # ================= VALIDACIONES =================
    @staticmethod
    def validar_nombre(nombre):

        if not nombre.strip():
            raise ValueError(
                "El nombre no puede estar vacío."
            )

        if len(nombre) > 40:
            raise ValueError(
                "El nombre no puede superar 40 caracteres."
            )

        for caracter in nombre:
            if caracter.isdigit():
                raise ValueError(
                    "El nombre no puede contener números."
                )

    @staticmethod
    def validar_telefono(telefono):

        telefono = str(telefono)

        if not telefono.isdigit():
            raise ValueError(
                "El teléfono solo debe contener números."
            )

        if len(telefono) != 10:
            raise ValueError(
                "El teléfono debe tener 10 dígitos."
            )

    # ================= GETTERS =================
    def get_nombre(self):
        return self._nombre

    def get_telefono(self):
        return self._telefono

    # ================= MOSTRAR =================
    def mostrar_datos(self):

        return (
            f"Nombre: {self._nombre}\n"
            f"Teléfono: {self._telefono}"
        )


# =========================================================
# CLASE CONTACTO
# =========================================================
class Contacto(Persona):

    CATEGORIAS_VALIDAS = [
        "Trabajo",
        "Universidad",
        "Familia",
        "Personal"
    ]

    def __init__(
        self,
        nombre,
        telefono,
        correo,
        ciudad,
        categoria
    ):

        super().__init__(nombre, telefono)

        self.validar_correo(correo)
        self.validar_ciudad(ciudad)
        self.validar_categoria(categoria)

        self._correo = correo
        self._ciudad = ciudad
        self._categoria = categoria

    # ================= VALIDACIONES =================
    @staticmethod
    def validar_correo(correo):

        if "@" not in correo or "." not in correo:
            raise ValueError(
                "Correo electrónico inválido."
            )

    @staticmethod
    def validar_ciudad(ciudad):

        if not ciudad.strip():
            raise ValueError(
                "La ciudad no puede estar vacía."
            )

    @staticmethod
    def validar_categoria(categoria):

        if categoria not in Contacto.CATEGORIAS_VALIDAS:
            raise ValueError(
                "Categoría inválida."
            )

    # ================= GETTERS =================
    def get_correo(self):
        return self._correo

    def get_ciudad(self):
        return self._ciudad

    def get_categoria(self):
        return self._categoria

    # ================= TXT =================
    def convertir_a_txt(self):

        return (
            f"{self._nombre}|"
            f"{self._telefono}|"
            f"{self._correo}|"
            f"{self._ciudad}|"
            f"{self._categoria}"
        )

    @classmethod
    def crear_desde_txt(cls, linea):

        datos = linea.strip().split("|")

        if len(datos) != 5:
            raise ValueError(
                "Formato TXT inválido."
            )

        return cls(
            datos[0],
            datos[1],
            datos[2],
            datos[3],
            datos[4]
        )

    # ================= MOSTRAR =================
    def mostrar_datos(self):

        return (
            f"Nombre: {self._nombre}\n"
            f"Teléfono: {self._telefono}\n"
            f"Correo: {self._correo}\n"
            f"Ciudad: {self._ciudad}\n"
            f"Categoría: {self._categoria}"
        )


# =========================================================
# CLASE AGENDA
# =========================================================
class Agenda:

    def __init__(self, ruta_archivo):

        self._ruta_archivo = ruta_archivo

        if not os.path.exists(self._ruta_archivo):

            with open(
                self._ruta_archivo,
                "w",
                encoding="utf-8"
            ):
                pass

    # =====================================================
    # LEER CONTACTOS
    # =====================================================
    def leer_contactos(self):

        contactos = []

        with open(
            self._ruta_archivo,
            "r",
            encoding="utf-8"
        ) as archivo:

            for linea in archivo:

                if linea.strip():

                    contacto = Contacto.crear_desde_txt(
                        linea
                    )

                    contactos.append(contacto)

        return contactos

    # =====================================================
    # GUARDAR CONTACTOS
    # =====================================================
    def guardar_contactos(self, contactos):

        with open(
            self._ruta_archivo,
            "w",
            encoding="utf-8"
        ) as archivo:

            for contacto in contactos:

                archivo.write(
                    contacto.convertir_a_txt() + "\n"
                )

    # =====================================================
    # AGREGAR CONTACTO
    # =====================================================
    def agregar_contacto(self, nuevo_contacto):

        contactos = self.leer_contactos()

        for contacto in contactos:

            if (
                contacto.get_telefono()
                ==
                nuevo_contacto.get_telefono()
            ):

                raise ValueError(
                    "Ya existe un contacto con ese teléfono."
                )

            if (
                contacto.get_correo().lower()
                ==
                nuevo_contacto.get_correo().lower()
            ):

                raise ValueError(
                    "Ya existe un contacto con ese correo."
                )

        contactos.append(nuevo_contacto)

        self.guardar_contactos(contactos)

    # =====================================================
    # BUSCAR CONTACTO
    # =====================================================
    def buscar_contacto(self, telefono):

        contactos = self.leer_contactos()

        for contacto in contactos:

            if contacto.get_telefono() == telefono:
                return contacto

        return None

    # =====================================================
    # ELIMINAR CONTACTO
    # =====================================================
    def eliminar_contacto(self, telefono):

        contactos = self.leer_contactos()

        nuevos_contactos = []

        eliminado = False

        for contacto in contactos:

            if contacto.get_telefono() != telefono:
                nuevos_contactos.append(contacto)

            else:
                eliminado = True

        if not eliminado:
            raise ValueError(
                "No se encontró el contacto."
            )

        self.guardar_contactos(nuevos_contactos)

    # =====================================================
    # ACTUALIZAR CONTACTO
    # =====================================================
    def actualizar_contacto(
        self,
        telefono_original,
        contacto_actualizado
    ):

        contactos = self.leer_contactos()

        actualizado = False

        for i in range(len(contactos)):

            if (
                contactos[i].get_telefono()
                ==
                telefono_original
            ):

                contactos[i] = contacto_actualizado

                actualizado = True

                break

        if not actualizado:
            raise ValueError(
                "No se encontró el contacto."
            )

        self.guardar_contactos(contactos)

    # =====================================================
    # REPORTES
    # =====================================================
    def total_contactos(self):

        return len(self.leer_contactos())

    def total_ciudades(self):

        ciudades = set()

        for contacto in self.leer_contactos():
            ciudades.add(contacto.get_ciudad())

        return len(ciudades)

    def total_categorias(self):

        categorias = set()

        for contacto in self.leer_contactos():
            categorias.add(contacto.get_categoria())

        return len(categorias)


